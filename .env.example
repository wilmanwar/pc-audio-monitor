# Home Assistant Configuration
HA_HOST=192.168.68.30
HA_PORT=8123
HA_TOKEN=your_long_lived_access_token_here
HA_NOTIFY_SERVICE=notify.notify

# Audio Detection Settings
AUDIO_THRESHOLD_DB=-40
MONITOR_INTERVAL_SECONDS=60
AUDIO_CHUNK_DURATION_SECONDS=2
ALERT_COOLDOWN_SECONDS=60

# Alert Scheduling (0-23 hours, 24-hour format)
# Examples:
#   ALERT_START_HOUR=8, ALERT_END_HOUR=22    (8am to 10pm)
#   ALERT_START_HOUR=9, ALERT_END_HOUR=17    (9am to 5pm)
#   ALERT_START_HOUR=0, ALERT_END_HOUR=24    (all day - default)
#   ALERT_START_HOUR=22, ALERT_END_HOUR=6    (10pm to 6am overnight)
ALERT_START_HOUR=0
ALERT_END_HOUR=24

# Logging
LOG_LEVEL=INFO
LOG_FILE=pc_audio_monitor.log
