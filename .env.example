# ============================================================
# PC Audio Monitor — Configuration
# ============================================================

# --- Home Assistant (local or Nabu Casa cloud) ---
HA_HOST=192.168.68.30        # IP or hostname (or your.ui.nabu.casa address)
HA_TOKEN=your_long_lived_token_here
HA_PORT=8123
HA_HTTPS=false               # Set true if using Nabu Casa or SSL

# --- Pushover (remote push notifications — works anywhere) ---
# Sign up free at https://pushover.net
# Create an app at https://pushover.net/apps/build to get PUSHOVER_TOKEN
PUSHOVER_TOKEN=              # Your app's API token
PUSHOVER_USER=               # Your user key (on pushover.net dashboard)

# --- Audio Settings ---
AUDIO_THRESHOLD_DB=-40       # Volume below this = silence (-60 to -20)
AUDIO_CHUNK_DURATION_SECONDS=3.0   # Audio chunk length for analysis
AUDIO_SAMPLE_RATE=44100      # 44100 or 48000
MONITOR_INTERVAL_SECONDS=10  # How often to check (seconds)
AUTO_DETECT_AUDIO=true       # Auto-detect best audio device

# --- Alert Behavior ---
ALERT_COOLDOWN_SECONDS=300   # Minimum seconds between repeat alerts (default 5 min)
ALERT_AFTER_SECONDS=180      # How long music must be absent before alerting (default 3 min)
GENRE_WINDOW=12              # Number of recent checks to average genre over
                             # At 5s interval, 12 = last 60 seconds of music

# --- Alert Schedule (24h format) ---
ALERT_START_HOUR=0           # Start sending alerts at this hour
ALERT_END_HOUR=24            # Stop sending alerts at this hour
# Examples:
#   Only 9am-5pm:          START=9  END=17
#   No alerts at night:    START=7  END=23
#   All day (default):     START=0  END=24

# --- Logging ---
LOG_LEVEL=INFO               # DEBUG, INFO, WARNING, ERROR
LOG_FILE=pc_audio_monitor.log
